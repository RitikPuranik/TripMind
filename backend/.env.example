# ─── TripMind Backend .env ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Minimum to run: GROQ_API_KEY + GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
SECRET_KEY=change-me-run-openssl-rand-hex-32

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
# Enable: Gmail API + Google Calendar API + Google+ API
# Redirect URI to add: http://localhost:8000/api/auth/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# ── LLM — pick ONE (both are completely free) ─────────────────────────────────
# OPTION A — Groq (RECOMMENDED): console.groq.com → API Keys → Create
#   → Llama 3.3 70B, fastest inference, unlimited free tier
GROQ_API_KEY=gsk_your_groq_key_here

# OPTION B — Google Gemini Flash: aistudio.google.com/app/apikey → Create API key
#   → 1500 requests/day free, no credit card
# GEMINI_API_KEY=AIza_your_gemini_key_here

# ── Optional APIs (all have free tiers, app works without them) ───────────────

# Foursquare Places — better venue data: developer.foursquare.com
# FOURSQUARE_API_KEY=fsq_your_key

# Google Maps — distance/directions: console.cloud.google.com
# GOOGLE_MAPS_API_KEY=AIza_your_maps_key

# AviationStack — flight gate changes: aviationstack.com (100 calls/month free)
# AVIATIONSTACK_API_KEY=your_key

# Twilio WhatsApp — weekly digests: twilio.com (free trial)
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=your_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Database — Supabase (optional) ───────────────────────────────────────────
# Without this, TripMind works fully but data resets when server restarts.
# Free tier at: supabase.com
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-role-key
# DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
